import {
  ADD_TASK,
  DELETE_TASK,
  DONE_TASK,
  EDIT_TASK,
} from "../actionType/todoActionType";

export const addTask = (newTask) => ({
  type: ADD_TASK,
  payload: newTask,
});

export const deleteTask = (id) => ({
  type: DELETE_TASK,
  payload: id,
});

export const doneTask = (id) => ({
  type: DONE_TASK,
  payload: id,
});

export const editTask = (id, descriptionToEdit) => ({
  type: EDIT_TASK,
  payload: { id, descriptionToEdit },
});